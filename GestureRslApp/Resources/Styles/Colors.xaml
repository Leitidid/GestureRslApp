<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ─── Светлая тема (по умолчанию) ─── -->

    <!-- Акцент — фиолетовый/синий -->
    <Color x:Key="Primary">#6750A4</Color>
    <Color x:Key="PrimaryLight">#E8DEF8</Color>

    <!-- Фоны -->
    <Color x:Key="PageBackground">#FFFBFE</Color>
    <Color x:Key="CardBackground">#FFF8F7</Color>

    <!-- Текст -->
    <Color x:Key="PrimaryText">#1C1B1F</Color>
    <Color x:Key="SecondaryText">#49454F</Color>

    <!-- Элементы -->
    <Color x:Key="DividerColor">#E0E0E0</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>

    <!-- Размеры шрифтов (обычные) -->
    <x:Double x:Key="FontSizeSmall">14</x:Double>
    <x:Double x:Key="FontSizeMedium">16</x:Double>
    <x:Double x:Key="FontSizeLarge">20</x:Double>
    <x:Double x:Key="FontSizeLetter">72</x:Double>

</ResourceDictionary>