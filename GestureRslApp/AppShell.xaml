<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:GestureRslApp.Pages"
       x:Class="GestureRslApp.AppShell"
       Shell.NavBarIsVisible="False">

    <!-- Нижняя навигация (TabBar) -->
    <TabBar>

        <!-- Вкладка 1: Камера -->
        <ShellContent
            Title="Камера"
            Icon="icon_camera.png"
            ContentTemplate="{DataTemplate pages:CameraPage}"
            Route="CameraPage" />

        <!-- Вкладка 2: История -->
        <ShellContent
            Title="История"
            Icon="icon_history.png"
            ContentTemplate="{DataTemplate pages:HistoryPage}"
            Route="HistoryPage" />

        <!-- Вкладка 3: Настройки -->
        <ShellContent
            Title="Настройки"
            Icon="icon_settings.png"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />

    </TabBar>
</Shell>
