<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestureRslApp.Pages.SettingsPage"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Настройки">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,16,0,32">

            <!-- ── ОТОБРАЖЕНИЕ ── -->
            <Label Text="ОТОБРАЖЕНИЕ"
                   FontSize="{StaticResource FontSizeSmall}"
                   TextColor="{StaticResource SecondaryText}"
                   FontAttributes="Bold"
                   Margin="20,0,20,8" />

            <Border Margin="16,0"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="Transparent">
                <VerticalStackLayout>

                    <!-- Режим для слабовидящих -->
                    <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Режим для слабовидящих"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryText}" />
                            <Label Text="Высокий контраст, крупный шрифт"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   TextColor="{StaticResource SecondaryText}" />
                        </VerticalStackLayout>
                        <Switch x:Name="HighContrastSwitch"
                                Grid.Column="1"
                                OnColor="{StaticResource Primary}"
                                VerticalOptions="Center"
                                Toggled="OnHighContrastToggled" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{StaticResource DividerColor}"
                             Margin="16,0" />

                    <!-- Текущая тема -->
                    <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Тема приложения"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryText}" />
                            <Label x:Name="ThemeLabel"
                                   Text="Светлая тема"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   TextColor="{StaticResource SecondaryText}" />
                        </VerticalStackLayout>
                        <Label x:Name="ThemeIcon"
                               Grid.Column="1"
                               Text="☀️"
                               FontSize="24"
                               VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ── О ПРИЛОЖЕНИИ ── -->
            <Label Text="О ПРИЛОЖЕНИИ"
                   FontSize="{StaticResource FontSizeSmall}"
                   TextColor="{StaticResource SecondaryText}"
                   FontAttributes="Bold"
                   Margin="20,24,20,8" />

            <Border Margin="16,0"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="Transparent">
                <VerticalStackLayout Padding="16,14" Spacing="8">
                    <Label Text="Распознавание РЖЯ"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryText}" />
                    <Label Text="Версия 2.0 — Полный алфавит + динамические жесты"
                           FontSize="{StaticResource FontSizeSmall}"
                           TextColor="{StaticResource SecondaryText}" />
                    <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,4" />
                    <Label Text="Статические буквы (27):"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryText}" />
                    <Label Text="А Б В Г Д Е Ё Ж И Л М Н О П Р С Т У Ф Х Ч Ш Ъ Ы Э Ю Я"
                           FontSize="{StaticResource FontSizeSmall}"
                           TextColor="{StaticResource SecondaryText}" />
                    <Label Text="Динамические буквы (6):"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryText}"
                           Margin="0,4,0,0" />
                    <Label Text="З  Й  К  Ц  Щ  Ь"
                           FontSize="{StaticResource FontSizeSmall}"
                           TextColor="{StaticResource SecondaryText}" />
                    <Label Text="Динамические слова (4):"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryText}"
                           Margin="0,4,0,0" />
                    <Label Text="МАМА  ПАПА  ПРИВЕТ  ПОКА"
                           FontSize="{StaticResource FontSizeSmall}"
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
